class Solution {
public:
    int minimumSwaps(vector<int>& nums) {
        int cnt = 0;
        int i = 0, j = nums.size() - 1;
        while (i < j) {
            while (i < j && nums[j] == 0)
                j--;

            if (i < j && nums[i] == 0) {
                swap(nums[i], nums[j]);
                cnt++;
            }
            i++;
        }
        return cnt;
    }
};