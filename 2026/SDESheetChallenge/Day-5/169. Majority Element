class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int i = 0, n = nums.size();
        int el, cnt = 0;

        while (i < n) {
            if (cnt == 0) {
                cnt++;
                el = nums[i];
            } else if (nums[i] == el) {
                cnt++;
            } else {
                cnt--;
            }
            i++;
        }

        return el;
    }
};