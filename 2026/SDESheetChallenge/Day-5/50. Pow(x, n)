class Solution {
public:
    double myPow(double x, int n) {
        long long N = n;
        double ans = 1.0;
        if (N < 0)
            N = -1LL * N;
        while (N) {
            if (N % 2 != 0) {
                ans *= x;
                N = N - 1;
            } else {
                x = x * x;
                N /= 2;
            }
        }
        if (n < 0)
            ans = 1.0 / ans;

        return ans;
    }
};